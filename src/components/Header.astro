---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <h2><a href="/" class="logo">{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
  </nav>
  <div class="header-ornament" aria-hidden="true">
    <span class="ornament-line"></span>
    <span class="ornament-symbol">&#10086;</span>
    <span class="ornament-line"></span>
  </div>
</header>
<style>
  header {
    margin: 0;
    padding: 1rem;
  }
  h2 {
    margin: 0;
    font-size: 1.5em;
  }

  h2 a,
  h2 a.active {
    font-weight: normal;
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-direction: column;
  }

  @media (min-width: 720px) {
    nav {
      flex-direction: row;
    }
  }

  nav a {
    padding: 1em 0.5em;
  }

  nav .logo {
    color: var(--accent);
  }

  .internal-links {
    font-size: 1rem;
  }

  .header-ornament {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.25rem;
  }

  .ornament-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(var(--gold), 100%) 20%,
      rgba(var(--gold), 100%) 80%,
      transparent
    );
  }

  .ornament-symbol {
    color: rgba(var(--gold), 100%);
    font-size: 0.9rem;
    line-height: 1;
  }
</style>
